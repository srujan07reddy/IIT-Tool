{
  "name": "coaching-ops-platform",
  "version": "1.0.0",
  "packageManager": "npm@8.0.0",
  "private": true,
  "description": "IIT Coaching Operations Platform Monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "test:api": "npm run test --prefix apps/api",
    "test:api:watch": "npm run test:watch --prefix apps/api",
    "test:api:e2e": "npm run test:e2e --prefix apps/api",
    "start:api": "npm run start:dev --prefix apps/api",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "clean": "npm run clean:modules && npm run clean:dist",
    "clean:modules": "rimraf **/node_modules",
    "clean:dist": "rimraf apps/*/dist packages/*/dist"
  },
  "devDependencies": {
    "prettier": "^3.0.0",
    "rimraf": "^5.0.0",
    "turbo": "latest",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "@nestjs/platform-express": "^11.1.19",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5"
  }
}
